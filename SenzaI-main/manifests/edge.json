{
  "manifest_version": 3,
  "name": "SenzaI",
  "author": "Abhidatta Benda",
  "description": "The ultimate minimalist quicklink launcher.",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icon/16.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "favicon"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com;"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "focus/*",
        "index.html",
        "icon/*",
        "style.css",
        "script/*",
        "version/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
